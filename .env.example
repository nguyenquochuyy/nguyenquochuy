# Environment Variables Example
# Copy this file to .env and fill in your values

# Database
# For Docker (recommended):
MONGODB_URI=mongodb://admin:password123@localhost:27017/unishop?authSource=admin
# For MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/unishop?retryWrites=true&w=majority

# JWT Secret
JWT_SECRET=your-secret-key-change-in-production

# Email Service (Gmail)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-16-chars

# Server
NODE_ENV=development
PORT=8080

# For Vercel Deployment
# Add these in Vercel Dashboard:
# MONGODB_URI = your-mongodb-connection-string
# EMAIL_USER = your-gmail-address
# EMAIL_PASS = your-gmail-app-password
# JWT_SECRET = your-jwt-secret
